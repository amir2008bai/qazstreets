# .env.local.example — скопируйте в .env.local и заполните

# 2ГИС MapGL токен — получите на https://dev.2gis.ru/
# Документация: https://docs.2gis.com/ru/mapgl/overview
NEXT_PUBLIC_2GIS_TOKEN=ваш_токен_2gis

# (опционально) Supabase для реальной базы данных
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Google Gemini API ключ для AI-модерации заявок (бесплатный)
# Получить на https://aistudio.google.com → Get API Key
NEXT_PUBLIC_GEMINI_KEY=ваш_ключ_gemini
